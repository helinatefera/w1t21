# ============================================================
# DEVELOPMENT ONLY — plaintext secrets are rejected unless
# APP_ENV is explicitly set to "development". When APP_ENV is
# unset or set to any other value, an encrypted keyfile is
# required. For staging/production, use: make generate-keyfile
# ============================================================
APP_ENV=development

DB_PASSWORD=changeme_db_password
JWT_SIGNING_KEY=changeme_jwt_secret_at_least_32_chars
AES_MASTER_KEY=changeme_aes_256_hex_key_64_chars
LISTEN_ADDR=:8080
DATABASE_URL=postgres://ledgermint:${DB_PASSWORD}@postgres:5432/ledgermint?sslmode=disable

# Staging / Production — requires an encrypted keyfile:
#   1. Run: make generate-keyfile
#   2. Set the variables below and remove all plaintext secrets above.
#
# APP_ENV=production
# SECRETS_KEYFILE=/run/secrets/ledgermint.enc
# SECRETS_PASSPHRASE=<your-passphrase>
